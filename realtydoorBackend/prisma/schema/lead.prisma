// ─── LEAD ─────────────────────────────────────────────────────────────────────
// Central unit of the anti-leakage engine (PRD §5).
// buyerPhone is stored plain; masking is computed at the API layer via formatPhone().
// siteVisitOTP is cleared from DB after successful verification.

model Lead {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  buyerName        String
  buyerEmail       String
  buyerPhone       String
  buyerId          String?    @db.ObjectId
  buyerMessage     String?
  propertyId       String     @db.ObjectId
  property         Property   @relation(fields: [propertyId], references: [id])
  status           LeadStatus @default(UNASSIGNED)
  assignedPartnerId String?   @db.ObjectId
  assignedPartner  User?      @relation("PartnerLeads", fields: [assignedPartnerId], references: [id])
  assignedAt       DateTime?
  adminNotes       String?

  // OTP anti-leakage (PRD §5 — Rules 1, 2, 3)
  siteVisitScheduledAt DateTime?
  siteVisitOTP         String?    // cleared after verification
  otpGeneratedAt       DateTime?
  otpExpiresAt         DateTime?  // = otpGeneratedAt + OTP_EXPIRY_MINUTES
  otpAttempts          Int        @default(0)
  otpLockedUntil       DateTime?  // set after OTP_MAX_ATTEMPTS failures
  isOtpVerified        Boolean    @default(false)
  otpVerifiedAt        DateTime?

  // WhatsApp buyer feedback cross-check (PRD §5 — Leakage 1)
  whatsappSentAt      DateTime?
  buyerFeedbackStatus BuyerFeedbackStatus?
  feedbackReceivedAt  DateTime?

  // Partner documentation
  visitNotes          String?
  visitPhotoUrls      String[]
  closureDocumentUrls String[]
  partnerNotes        String?

  // 7-day re-ping for STILL_DECIDING (Appendix C.4)
  secondFollowupSentAt DateTime?

  // Two-tier drop system (Appendix C.2)
  dropRequestedByPartner Boolean   @default(false)
  dropRequestNote        String?
  dropRequestedAt        DateTime?
  droppedReason          String?
  droppedAt              DateTime?
  droppedByAdminId       String?   @db.ObjectId

  // Commission summary (Phase 2 — §3.3)
  platformCommissionPct Float?
  commissionAmountPaise Int?
  commissionStatus      CommissionStatus @default(PENDING)
  invoiceUrl            String?
  invoicedAt            DateTime?
  collectedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  escrowTransactions EscrowTransaction[]

  @@index([assignedPartnerId])
  @@index([buyerId])
  @@index([status])
  @@index([propertyId])
  @@index([buyerFeedbackStatus])
  @@index([dropRequestedByPartner])
  @@index([assignedPartnerId, status])
  @@index([status, createdAt])
  @@index([propertyId, status])
  @@index([buyerId, createdAt])
  @@index([commissionStatus])
}
